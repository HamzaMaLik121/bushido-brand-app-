# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Bushido Brand
# Copy to .env and fill in real values. Never commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_DATABASE=bushido_db
MYSQL_USER=bushido_user
MYSQL_PASSWORD=CHANGE_ME_user_password

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
JWT_SECRET_KEY=CHANGE_ME_long_random_string_at_least_32_chars

# ── Image tags (overridden by Jenkins per build) ──────────────────────────────
FRONTEND_TAG=latest
BACKEND_TAG=latest
