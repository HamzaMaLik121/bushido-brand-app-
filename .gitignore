# Bushido Brand .gitignore

# ─── Shared Library (separate repo) ───────────────────────────────────────────
bushido-brand-pipeline/jenkins-shared-lib/

# ─── Environment ─────────────────────────────────────────────────────────────
.env
.env.local
*.env.local

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
.eggs/
dist/
build/

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-*

# ─── Reports & Artifacts ─────────────────────────────────────────────────────
reports/
*.log
trivy-report*.json
dependency-check-report*.xml

# ─── Docker ──────────────────────────────────────────────────────────────────
mysql_data/

# ─── GitOps temp ────────────────────────────────────────────────────────────
gitops-tmp/
