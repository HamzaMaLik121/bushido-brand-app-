# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Bushido Brand
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Security scan output (generated at build time) ────────────────────────────
security-reports/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
*.log

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~

# ── Trivy / OWASP caches ──────────────────────────────────────────────────────
.trivycache/
dep-check-data/
